  def __init__(self, trading_view_webhook_helpers):
    self.tvw_helpers = trading_view_webhook_helpers
    self.r = trading_view_webhook_helpers.require_redis()

  def _trade_stream_key(self, ticker: str) -> str:
    sym = str(ticker or "").upper().strip()
    return f"tv:trades:{sym}"

  def _trade_index_key(self) -> str:
    return "tv:trades:index"

  def _active_tickers_key(self) -> str:
    return "tv:tickers:active"

  def _price_stream_key(self, ticker: str) -> str:
    sym = str(ticker or "").upper().strip()
    return f"tv:mtm:{sym}"

  def create_trade_record(self, strategy_name, ticker, date, price, num_shares, side):
    sym = str(ticker or "").upper().strip()
    side = str(side or "").lower().strip()

    if side not in {"buy", "sell"}:
      raise ValueError(f"Invalid trade side: {side}")

    iso_dt = str(date or "").strip()
    if not iso_dt:
      iso_dt = datetime.now(timezone.utc).isoformat()

    try:
      ts_score = datetime.fromisoformat(iso_dt.replace("Z", "+00:00")).timestamp()
